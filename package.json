{
  "name": "@concavetrillion/pd-ui",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "description": "Shared TS/React/Vite frontend library for the pd-* suite",
  "author": "CT <concavetrillion@gmail.com>",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/ConcaveTrillion/pd-ui.git"
  },
  "homepage": "https://github.com/ConcaveTrillion/pd-ui",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://concavetrillion.github.io/pd-index-npm/"
  },
  "files": [
    "dist",
    "theme",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./canvas": {
      "import": "./dist/canvas.js",
      "types": "./dist/canvas.d.ts"
    },
    "./worklist": {
      "import": "./dist/worklist.js",
      "types": "./dist/worklist.d.ts"
    },
    "./shell": {
      "import": "./dist/shell.js",
      "types": "./dist/shell.d.ts"
    },
    "./primitives": {
      "import": "./dist/primitives.js",
      "types": "./dist/primitives.d.ts"
    },
    "./icons": {
      "import": "./dist/icons.js",
      "types": "./dist/icons.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./stores": {
      "import": "./dist/stores.js",
      "types": "./dist/stores.d.ts"
    },
    "./testids": {
      "import": "./dist/testids.js",
      "types": "./dist/testids.d.ts"
    },
    "./templates": {
      "import": "./dist/templates.js",
      "types": "./dist/templates.d.ts"
    },
    "./theme/tokens.css": "./theme/tokens.css",
    "./theme/primitives.css": "./theme/primitives.css"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-konva": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react-konva": {
      "optional": false
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.0.0",
    "@dnd-kit/sortable": "^7.0.0",
    "@dnd-kit/utilities": "^3.0.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.0.0",
    "@radix-ui/react-dialog": "^1.0.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@radix-ui/react-popover": "^1.0.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.0.0",
    "@radix-ui/react-toggle-group": "^1.0.0",
    "@radix-ui/react-tooltip": "^1.0.0",
    "@tanstack/react-virtual": "^3.0.0",
    "clsx": "^2.0.0",
    "konva": "^9.0.0",
    "lucide-react": "^0.400.0",
    "react-virtuoso": "^4.0.0",
    "zustand": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "react-konva": "^19.0.0",
    "@storybook/addon-a11y": "^8.0.0",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/addon-interactions": "^8.0.0",
    "@storybook/react": "^8.0.0",
    "@storybook/react-vite": "^8.0.0",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^24.0.0",
    "knip": "^6.14.2",
    "openapi-typescript": "^7.0.0",
    "prettier": "^3.8.3",
    "storybook": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^1.0.0"
  },
  "scripts": {
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "vite build",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\"",
    "knip": "knip",
    "codegen": "node scripts/codegen-fetch.mjs && node scripts/codegen-emit.mjs && node scripts/codegen-tsgen.mjs",
    "codegen:check": "node scripts/codegen-fetch.mjs && node scripts/codegen-emit.mjs && node scripts/codegen-tsgen.mjs && git diff --exit-code src/types/generated/",
    "sync:design-system": "node scripts/sync-design-system.mjs",
    "codegen:theme-check": "node scripts/sync-design-system.mjs --check",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static"
  }
}
